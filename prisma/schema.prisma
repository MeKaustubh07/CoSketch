// CoSketch — Prisma schema (no auth)
// Board: room metadata — canvas content lives in Liveblocks

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Board {
  id   String @id // nanoid — also serves as Liveblocks room ID
  name String @default("Untitled")

  // scrypt hash of the room password: "<salt>:<hash>"
  joinPassword String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
