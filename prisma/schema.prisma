// CoSketch — Prisma schema (no auth)
// Board: room metadata + scene snapshot. Canvas content synced via WebSocket,
// persisted here as a JSON blob.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Board {
  id           String   @id // nanoid — also serves as WS room ID
  name         String   @default("Untitled")
  joinPassword String

  // Full scene snapshot: { elements: { [id]: CanvasElement }, elementOrder: string[] }
  // Loaded into memory by the WS server on first join; saved back on change.
  scene        Json     @default("{\"elements\":{},\"elementOrder\":[]}")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
