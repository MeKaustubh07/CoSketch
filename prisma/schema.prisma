// CoSketch — Prisma schema
// Models: Auth.js adapter (User, Account, Session, VerificationToken)
//         + Board (metadata only — canvas content lives in Liveblocks)
//         + BoardCollaborator (access control)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js adapter models ──────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?   // nullable — only set for credentials login

  createdAt DateTime @default(now())

  accounts       Account[]
  sessions       Session[]
  ownedBoards    Board[]             @relation("BoardOwner")
  collaborations BoardCollaborator[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application models ──────────────────────────────────────────────────────

model Board {
  // 8-char nanoid — also serves as the Liveblocks room ID and the
  // human-readable "Room ID" shown in the Share panel.
  id   String @id // NOT auto-generated — we set this to a nanoid in the API route
  name String @default("Untitled")

  ownerId String
  owner   User   @relation("BoardOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  // AES-256-GCM encrypted (not bcrypt-hashed) — the owner needs to
  // re-display it in the Share panel. Format: iv:ciphertext:authTag (hex).
  joinPassword String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  collaborators BoardCollaborator[]
}

model BoardCollaborator {
  boardId  String
  userId   String
  joinedAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
}
